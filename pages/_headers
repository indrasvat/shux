# Cloudflare Pages headers — applies to every response served from
# shux.pages.dev. CF processes this at deploy time.
#
# CSP allows: self for everything, fonts.googleapis.com + fonts.gstatic.com
# for the Inter / JetBrains Mono webfonts. Images allow data: for the
# inline SVG noise overlay. connect-src allows api.github.com for the
# version-bump fetch at the bottom of index.html.

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), camera=(), microphone=(), payment=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self'; frame-ancestors 'self'

# Long-cache the immutable assets; let index.html stay fresh.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

/screenshots/*
  Cache-Control: public, max-age=31536000, immutable

/styles/*
  Cache-Control: public, max-age=31536000, immutable

/scripts/*
  Cache-Control: public, max-age=31536000, immutable
