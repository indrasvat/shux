# Generated by Cargo
# will have compiled files and executables
debug
target

# `cargo test -p shux-plugin` runs from `crates/shux-plugin/` and the
# default PluginManager::new constructs its state root from cwd, which
# leaves a stray `.shux/plugins/` tree under the crate. Not committed.
crates/*/.shux/

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
.idea/
.vscode/

.local/

dist/

*.log
*.env

.claude/screenshots/
.claude/automations/screenshots/
.claude/RESUME.md
.claude/scheduled_tasks.lock
.codemap/

.DS_Store
.DS_STORE

# Task runner logs
.task-runs/

# Coverage
lcov.info
tarpaulin-report.html

# Fuzz
fuzz/artifacts/
fuzz/corpus/

# Lefthook
.lefthook-local/

# Release tooling (semantic-release npm tools + binary staging).
node_modules/
artifacts/
staging/

# Cloudflare Pages local dev cache (regenerated by `wrangler pages dev`).
.wrangler/
